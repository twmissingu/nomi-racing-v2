; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text.

[application]

config/name="NOMI Racing"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

InputManager="*res://autoloads/input_manager.gd"
SaveManager="*res://autoloads/save_manager.gd"
GameManager="*res://autoloads/game_manager.gd"
RaceManager="*res://autoloads/race_manager.gd"
AchievementManager="*res://autoloads/achievement_manager.gd"
SoundManager="*res://autoloads/sound_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[physics]

common/physics_ticks_per_second=120

[rendering]

anti_aliasing/quality/msaa_3d=1
